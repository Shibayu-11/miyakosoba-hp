# --- 必須(設定しないと地図が表示されない) ---

# Google Maps JavaScript API キー
# 取得: https://console.cloud.google.com/google/maps-apis/credentials
# 必要なAPI: Maps JavaScript API
# 必須: HTTPリファラ制限 (localhost / 本番ドメイン)
VITE_GOOGLE_MAPS_API_KEY=

# Map ID (任意。AdvancedMarker / カスタムスタイルを使う場合)
VITE_GOOGLE_MAPS_MAP_ID=

# サイトURL (構造化データやOGに使用)
VITE_SITE_URL=https://miyakosoba.example.com

# --- 任意(SNS) ---

VITE_LINE_URL=
VITE_INSTAGRAM_URL=
VITE_X_URL=

# --- 任意(GA4) ---

# 取得: https://analytics.google.com/ (G-XXXXXXX 形式)
VITE_GA_MEASUREMENT_ID=

# --- 任意(microCMS / 後日切替) ---

# https://microcms.io でサービス作成後に取得
VITE_MICROCMS_SERVICE_DOMAIN=
VITE_MICROCMS_API_KEY=
